<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="attendance_checkin_template" name="Attendance Check-in Mobile">
        <html lang="vi">
        <head>
            <meta charset="UTF-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
            <title>Chấm Công — BBSW</title>
            <!-- PWA / Add to Home Screen -->
            <meta name="mobile-web-app-capable" content="yes"/>
            <meta name="apple-mobile-web-app-capable" content="yes"/>
            <meta name="apple-mobile-web-app-status-bar-style" content="default"/>
            <meta name="apple-mobile-web-app-title" content="Chấm Công"/>
            <meta name="theme-color" content="#16a34a"/>
            <link rel="manifest" href="/bbsw_thuchi/static/src/manifest_checkin.json"/>
            <link rel="apple-touch-icon" href="/bbsw_thuchi/static/src/img/checkin_icon.svg"/>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap"/>
            <link rel="stylesheet" t-att-href="'/bbsw_thuchi/static/src/css/attendance_checkin.css'"/>
        </head>
        <body>

        <div class="ac-wrap" id="acWrap" t-att-data-checked-in="'true' if is_checked_in else 'false'">

            <!-- Header -->
            <div class="ac-header">
                <a href="/project/home" class="ac-back">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <span class="ac-title">Chấm Công</span>
                <div class="ac-user-avatar">
                    <img t-attf-src="/web/image?model=res.users&amp;id={{ current_user.id }}&amp;field=avatar_128"
                         alt="Avatar"/>
                </div>
            </div>

            <!-- Date + Clock -->
            <div class="ac-time-section">
                <div class="ac-date" id="acDate"><t t-esc="date_str"/></div>
                <div class="ac-clock" id="acClock">--:--:--</div>
            </div>

            <!-- Employee info -->
            <div class="ac-employee">
                <t t-if="employee">
                    <div class="ac-emp-name"><t t-esc="employee.name"/></div>
                    <div class="ac-emp-dept">
                        <t t-if="employee.department_id">
                            <t t-esc="employee.department_id.name"/>
                        </t>
                        <t t-else="">BBSW</t>
                    </div>
                </t>
                <t t-else="">
                    <div class="ac-emp-name ac-no-emp">Tài khoản chưa liên kết nhân viên</div>
                </t>
            </div>

            <!-- Status Card -->
            <t t-if="employee">
                <div class="ac-status-card" id="acStatusCard">
                    <t t-if="is_checked_in">
                        <div class="ac-status-icon ac-icon-in">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div class="ac-status-label" id="acStatusLabel">Đang làm việc</div>
                        <div class="ac-status-sub" id="acStatusSub">Vào ca lúc <strong id="acCheckinTime"><t t-esc="checkin_str"/></strong></div>
                        <div class="ac-elapsed" id="acElapsed"></div>
                    </t>
                    <t t-else="">
                        <div class="ac-status-icon ac-icon-out">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div class="ac-status-label" id="acStatusLabel">Chưa vào ca</div>
                        <div class="ac-status-sub" id="acStatusSub">Bấm nút bên dưới để bắt đầu</div>
                        <div class="ac-elapsed" id="acElapsed"></div>
                    </t>
                </div>

                <!-- GPS Status -->
                <div class="ac-gps-status" id="acGpsStatus"></div>

                <!-- Action Button -->
                <div class="ac-btn-wrap">
                    <button class="ac-btn" id="acBtn" onclick="acHandleClick()">
                        <span class="ac-btn-inner" id="acBtnInner">
                            <t t-if="is_checked_in">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                </svg>
                                <span>RA CA</span>
                            </t>
                            <t t-else="">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                                </svg>
                                <span>VÀO CA</span>
                            </t>
                        </span>
                    </button>
                </div>

                <!-- Today History -->
                <div class="ac-history" id="acHistory">
                    <div class="ac-history-title" style="display:flex;justify-content:space-between;align-items:center">
                        <span>Hôm nay</span>
                        <a href="/attendance/history" style="font-size:12px;color:#16a34a;font-weight:600;text-decoration:none">
                            Xem lịch sử ›
                        </a>
                    </div>
                    <div id="acHistoryList"></div>
                </div>

                <!-- Camera Modal (hiện khi ngoài bán kính) -->
                <div class="ac-camera-modal" id="acCameraModal" style="display:none">
                    <div class="ac-camera-overlay">
                        <div class="ac-camera-box">
                            <div class="ac-camera-header">
                                <span class="ac-camera-title">📷 Chụp ảnh xác nhận</span>
                                <button class="ac-camera-close" id="acCameraClose">✕</button>
                            </div>
                            <div class="ac-camera-notice" id="acCameraNotice"></div>
                            <div class="ac-camera-preview">
                                <video id="acVideo" autoplay="1" playsinline="1" muted="1"></video>
                                <canvas id="acCanvas" style="display:none"></canvas>
                                <img id="acPhotoPreview" style="display:none" alt="Ảnh chụp"/>
                            </div>
                            <div class="ac-camera-actions">
                                <button class="ac-camera-btn-capture" id="acCaptureBtn">📸 Chụp ảnh</button>
                                <button class="ac-camera-btn-retake" id="acRetakeBtn" style="display:none">🔄 Chụp lại</button>
                                <button class="ac-camera-btn-submit" id="acSubmitPhotoBtn" style="display:none">✅ Xác nhận chấm công</button>
                            </div>
                        </div>
                    </div>
                </div>
            </t>

            <!-- Toast notification -->
            <div class="ac-toast" id="acToast"></div>

            <!-- Add to Home Screen banner -->
            <div class="ac-install-banner" id="acInstallBanner" style="display:none">
                <div class="ac-install-content">
                    <div class="ac-install-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div class="ac-install-text">
                        <strong>Thêm vào màn hình chính</strong>
                        <span>Truy cập chấm công nhanh hơn</span>
                    </div>
                    <button class="ac-install-btn" id="acInstallBtn">Thêm</button>
                    <button class="ac-install-close" id="acInstallClose">✕</button>
                </div>
            </div>

        </div>

        <script>
            var AC_CHECKED_IN = <t t-out="'true' if is_checked_in else 'false'"/>;
            var AC_CHECKIN_TIME = "<t t-esc="checkin_str"/>";
            var AC_TODAY_RECORDS = <t t-out="today_records_json"/>;
        </script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script t-att-src="'/bbsw_thuchi/static/src/js/attendance_checkin.js'"></script>
        </body>
        </html>
    </template>

</odoo>
