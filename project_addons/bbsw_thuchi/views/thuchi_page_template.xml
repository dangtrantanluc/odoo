<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="thuchi_page_template" name="Thu Chi Page">
        <html lang="vi">
        <head>
            <meta charset="UTF-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
            <title>Thu Chi — BBSW</title>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap"/>
            <link rel="stylesheet" t-att-href="'/bbsw_thuchi/static/src/css/thuchi_homepage.css'"/>
            <link rel="stylesheet" t-att-href="'/bbsw_thuchi/static/src/css/thuchi_page.css'"/>
        </head>
        <body class="tc-body">

        <!-- ── Header ── -->
        <header class="tc-header">
            <div class="tc-header-inner">
                <div class="tc-header-left">
                    <a href="/project/home" class="tc-back-btn" title="Trang chủ">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </a>
                    <div class="tc-title">
                        <div class="tc-title-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div>
                            <h1>Thu Chi</h1>
                            <p>Quản lý thu nhập &amp; chi tiêu</p>
                        </div>
                    </div>
                </div>

                <div class="tc-header-right">
                    <!-- Month picker -->
                    <div class="tc-month-picker" id="monthPicker">
                        <button class="tc-month-btn" id="monthBtn" type="button">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span id="monthLabel">Tháng...</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="tc-chevron">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div class="tc-month-dropdown" id="monthDropdown"></div>
                    </div>

                    <!-- Add button -->
                    <button class="tc-add-btn" id="openCreateModal" type="button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        <span>Tạo mới</span>
                    </button>

                    <!-- User dropdown -->
                    <div class="dropdown">
                        <button type="button" class="hp-user-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <img t-attf-src="/web/image?model=res.users&amp;id={{ current_user.id }}&amp;field=avatar_128"
                                 alt="Avatar" class="hp-avatar"/>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="13" height="13" class="hp-chevron">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end hp-dropdown">
                            <div class="hp-dd-header">
                                <strong><t t-esc="current_user.name"/></strong>
                                <small><t t-esc="current_user.email"/></small>
                            </div>
                            <div class="dropdown-divider"/>
                            <a href="/project/home" class="dropdown-item">Trang chủ</a>
                            <t t-if="is_admin">
                                <div class="dropdown-divider"/>
                                <span class="dropdown-item-text text-muted" style="font-size:11px;padding:4px 16px;">Cấu hình</span>
                                <a href="/odoo/thuchi/bbsw-thuchi-category" class="dropdown-item">Danh mục</a>
                                <a href="/odoo/thuchi/bbsw-business-unit" class="dropdown-item">Đơn vị kinh doanh</a>
                                <a href="/odoo/thuchi/bbsw-payment-method" class="dropdown-item">Phương thức thanh toán</a>
                                <a href="/odoo/thuchi/bbsw-thuchi-project" class="dropdown-item">Dự án</a>
                            </t>
                            <div class="dropdown-divider"/>
                            <a href="/web/session/logout?redirect=/" class="dropdown-item text-danger">Đăng xuất</a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- ── Main ── -->
        <main class="tc-main">

            <!-- Stats row -->
            <div class="tc-stats">
                <div class="tc-stat-card tc-stat-thu">
                    <div class="tc-stat-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"/>
                        </svg>
                    </div>
                    <div>
                        <div class="tc-stat-label">Tổng Thu</div>
                        <div class="tc-stat-value" id="statThu">—</div>
                    </div>
                </div>
                <div class="tc-stat-card tc-stat-chi">
                    <div class="tc-stat-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"/>
                        </svg>
                    </div>
                    <div>
                        <div class="tc-stat-label">Tổng Chi</div>
                        <div class="tc-stat-value" id="statChi">—</div>
                    </div>
                </div>
                <div class="tc-stat-card tc-stat-balance" id="balanceCard">
                    <div class="tc-stat-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
                        </svg>
                    </div>
                    <div>
                        <div class="tc-stat-label">Cân đối</div>
                        <div class="tc-stat-value" id="statBalance">—</div>
                    </div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="tc-toolbar">
                <div class="tc-type-tabs" id="typeTabs">
                    <button class="tc-tab active" data-type="all" type="button">Tất cả</button>
                    <button class="tc-tab" data-type="thu" type="button">Thu</button>
                    <button class="tc-tab" data-type="chi" type="button">Chi</button>
                    <button class="tc-tab" data-type="vay" type="button">Vay</button>
                    <button class="tc-tab" data-type="hoan_ung" type="button">Hoàn ứng</button>
                </div>
                <div class="tc-search-box">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input type="text" id="searchInput" placeholder="Tìm mã GD, mô tả..." autocomplete="off"/>
                </div>
            </div>

            <!-- List -->
            <div class="tc-list-wrap">
                <div class="tc-loading" id="loadingState">
                    <div class="tc-spinner"></div>
                    <span>Đang tải...</span>
                </div>
                <div class="tc-empty" id="emptyState" style="display:none">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <p>Chưa có giao dịch nào trong tháng này</p>
                    <button class="tc-add-btn" id="openCreateModal2" type="button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        <span>Tạo giao dịch đầu tiên</span>
                    </button>
                </div>
                <div id="recordsTable" style="display:none">
                    <div class="tc-table-scroll">
                        <table class="tc-table">
                            <thead>
                                <tr>
                                    <th>Mã GD</th>
                                    <th>Ngày</th>
                                    <th>Mô tả</th>
                                    <th>Loại</th>
                                    <th>Danh mục</th>
                                    <th>Đơn vị</th>
                                    <th>Dự án</th>
                                    <th>Đối tượng</th>
                                    <th>Thanh toán</th>
                                    <th class="text-end">Số tiền</th>
                                    <th>TT Thanh toán</th>
                                    <th>Trạng thái</th>
                                    <th>Đính kèm</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody id="recordsTbody"></tbody>
                        </table>
                    </div>
                </div>
            </div>

        </main>

        <!-- ── Modal: Create/Edit ── -->
        <div class="tc-modal-backdrop" id="modalBackdrop">
            <div class="tc-modal tc-modal-lg" id="createModal">
                <div class="tc-modal-header">
                    <h3 id="modalTitle">Tạo giao dịch mới</h3>
                    <button class="tc-modal-close" id="closeModal" type="button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
                <div class="tc-modal-body">
                    <input type="hidden" id="editRecordId"/>

                    <!-- Row 1: Type + Date -->
                    <div class="tc-form-row">
                        <div class="tc-form-group">
                            <label>Loại giao dịch <span class="req">*</span></label>
                            <div class="tc-type-toggle" id="typeToggle">
                                <button class="tc-type-opt tc-type-chi" data-val="chi" type="button">Chi tiêu</button>
                                <button class="tc-type-opt tc-type-thu" data-val="thu" type="button">Thu nhập</button>
                                <button class="tc-type-opt tc-type-vay" data-val="vay" type="button">Vay</button>
                                <button class="tc-type-opt tc-type-hoan" data-val="hoan_ung" type="button">Hoàn ứng</button>
                            </div>
                        </div>
                        <div class="tc-form-group">
                            <label for="fDate">Ngày <span class="req">*</span></label>
                            <input type="date" id="fDate"/>
                        </div>
                    </div>

                    <!-- Row 2: Amount + Category -->
                    <div class="tc-form-row">
                        <div class="tc-form-group">
                            <label for="fAmount">Số tiền <span class="req">*</span></label>
                            <div class="tc-amount-input">
                                <input type="number" id="fAmount" placeholder="0" min="1" step="1000"/>
                                <span class="tc-currency">₫</span>
                            </div>
                        </div>
                        <div class="tc-form-group">
                            <label for="fCategory">Danh mục <span class="req">*</span></label>
                            <select id="fCategory">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>
                    </div>

                    <!-- Row 3: Description -->
                    <div class="tc-form-group">
                        <label for="fName">Mô tả <span class="req">*</span></label>
                        <input type="text" id="fName" placeholder="Nhập mô tả giao dịch..."/>
                    </div>

                    <!-- Row 4: Business Unit + Project -->
                    <div class="tc-form-row">
                        <div class="tc-form-group">
                            <label for="fBusinessUnit">Đơn vị kinh doanh</label>
                            <select id="fBusinessUnit">
                                <option value="">-- Chọn đơn vị --</option>
                            </select>
                        </div>
                        <div class="tc-form-group">
                            <label for="fProject">Dự án</label>
                            <select id="fProject">
                                <option value="">-- Chọn dự án --</option>
                            </select>
                        </div>
                    </div>

                    <!-- Row 5: Object type + Object name -->
                    <div class="tc-form-row">
                        <div class="tc-form-group">
                            <label for="fObjectType">Loại đối tượng</label>
                            <select id="fObjectType">
                                <option value="partner">Đối tác / Khách hàng</option>
                                <option value="employee">Nhân viên</option>
                                <option value="student">Học sinh / Sinh viên</option>
                                <option value="other">Khác</option>
                            </select>
                        </div>
                        <div class="tc-form-group" id="fPartnerWrap">
                            <label for="fPartner">Đối tác</label>
                            <select id="fPartner">
                                <option value="">-- Chọn đối tác --</option>
                            </select>
                        </div>
                        <div class="tc-form-group" id="fEmployeeWrap" style="display:none">
                            <label for="fEmployee">Nhân viên</label>
                            <select id="fEmployee">
                                <option value="">-- Chọn nhân viên --</option>
                            </select>
                        </div>
                        <div class="tc-form-group" id="fStudentWrap" style="display:none">
                            <label for="fStudentName">Tên học sinh/sinh viên</label>
                            <input type="text" id="fStudentName" placeholder="Nhập tên..."/>
                        </div>
                        <div class="tc-form-group" id="fOtherWrap" style="display:none">
                            <label for="fOtherName">Tên đối tượng</label>
                            <input type="text" id="fOtherName" placeholder="Nhập tên..."/>
                        </div>
                    </div>

                    <!-- Row 6: Payment method + Payment status -->
                    <div class="tc-form-row">
                        <div class="tc-form-group">
                            <label for="fPaymentMethod">Phương thức thanh toán</label>
                            <select id="fPaymentMethod">
                                <option value="">-- Chọn PTTT --</option>
                            </select>
                        </div>
                        <div class="tc-form-group">
                            <label for="fPaymentStatus">Trạng thái thanh toán</label>
                            <select id="fPaymentStatus">
                                <option value="unpaid">Chưa thanh toán</option>
                                <option value="paid">Đã thanh toán</option>
                            </select>
                        </div>
                    </div>

                    <!-- Row 7: Note -->
                    <div class="tc-form-group">
                        <label for="fNote">Ghi chú</label>
                        <textarea id="fNote" rows="2" placeholder="Ghi chú thêm (tùy chọn)..."></textarea>
                    </div>

                    <!-- Row 8: Attachments -->
                    <div class="tc-form-group">
                        <label>Chứng từ đính kèm</label>
                        <div id="modalAttachList" class="tc-attach-list tc-attach-list-sm"></div>
                        <label class="tc-attach-upload-label tc-attach-upload-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                            </svg>
                            <span>Chọn file đính kèm</span>
                            <input type="file" id="modalAttachInput" multiple="multiple" style="display:none"/>
                        </label>
                        <div id="modalAttachProgress" style="display:none" class="tc-attach-progress">Đang tải lên...</div>
                    </div>
                </div>
                <div class="tc-modal-footer">
                    <button class="tc-btn-ghost" id="cancelModal" type="button">Hủy</button>
                    <div class="tc-modal-footer-right">
                        <button class="tc-btn-secondary" id="saveDraft" type="button">Lưu nháp</button>
                        <button class="tc-btn-primary" id="saveConfirm" type="button">Lưu &amp; Gửi duyệt</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Modal: View Detail ── -->
        <div class="tc-modal-backdrop" id="viewBackdrop">
            <div class="tc-modal tc-modal-lg" id="viewModal">
                <div class="tc-modal-header">
                    <h3 id="viewModalTitle">Chi tiết giao dịch</h3>
                    <button class="tc-modal-close" id="closeViewModal" type="button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
                <div class="tc-modal-body" id="viewModalBody"></div>
                <div class="tc-modal-footer">
                    <button class="tc-btn-ghost" id="closeViewModalBtn" type="button">Đóng</button>
                    <button class="tc-btn-primary" id="viewToEditBtn" type="button">Chỉnh sửa</button>
                </div>
            </div>
        </div>

        <!-- ── Modal: Delete Confirm ── -->
        <div class="tc-modal-backdrop" id="deleteBackdrop">
            <div class="tc-modal tc-modal-sm">
                <div class="tc-modal-header">
                    <h3>Xóa giao dịch</h3>
                    <button class="tc-modal-close" id="closeDeleteModal" type="button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
                <div class="tc-modal-body">
                    <p class="tc-delete-msg">Bạn có chắc chắn muốn xóa giao dịch<br/><strong id="deleteRecordName"></strong>?</p>
                    <p class="tc-delete-warn">Hành động này không thể hoàn tác.</p>
                </div>
                <div class="tc-modal-footer">
                    <button class="tc-btn-ghost" id="cancelDelete" type="button">Hủy</button>
                    <button class="tc-btn-danger" id="confirmDelete" type="button">Xóa</button>
                </div>
            </div>
        </div>

        <!-- ── Modal: Attachments ── -->
        <div class="tc-modal-backdrop" id="attachBackdrop">
            <div class="tc-modal tc-modal-sm" id="attachModal">
                <div class="tc-modal-header">
                    <h3>Chứng từ đính kèm</h3>
                    <button class="tc-modal-close" id="closeAttachModal" type="button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
                <div class="tc-modal-body">
                    <input type="hidden" id="attachRecordId"/>
                    <div id="attachList" class="tc-attach-list"></div>
                    <label class="tc-attach-upload-label">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        <span>Tải lên chứng từ</span>
                        <input type="file" id="attachFileInput" multiple="multiple" style="display:none"/>
                    </label>
                    <div id="attachUploadProgress" style="display:none" class="tc-attach-progress">Đang tải lên...</div>
                </div>
                <div class="tc-modal-footer">
                    <button class="tc-btn-ghost" id="closeAttachModalBtn" type="button">Đóng</button>
                </div>
            </div>
        </div>

        <!-- Toast -->
        <div class="tc-toast" id="toast"></div>

        <!-- Data bridge -->
        <script>
            window.BBSW = {
                categoriesThu:    <t t-out="categories_thu_json"/>,
                categoriesChi:    <t t-out="categories_chi_json"/>,
                categoriesVay:    <t t-out="categories_vay_json"/>,
                categoriesHoanUng:<t t-out="categories_hoan_ung_json"/>,
                businessUnits:    <t t-out="business_units_json"/>,
                paymentMethods:   <t t-out="payment_methods_json"/>,
                projects:         <t t-out="projects_json"/>,
                employees:        <t t-out="employees_json"/>,
                partners:         <t t-out="partners_json"/>,
                currentMonth:     <t t-out="current_month_json"/>
            };
        </script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script t-att-src="'/bbsw_thuchi/static/src/js/thuchi_page.js'"></script>

        </body>
        </html>
    </template>

</odoo>
