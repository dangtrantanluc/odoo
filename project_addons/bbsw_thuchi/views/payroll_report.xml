<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════ QWeb Report Template ═══════════════ -->
    <template id="report_payroll_template">
        <t t-call="web.html_container">
            <style>
                @font-face {
                    font-family: 'DejaVu Sans';
                    src: url('/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf');
                    font-weight: normal;
                }
                @font-face {
                    font-family: 'DejaVu Sans';
                    src: url('/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf');
                    font-weight: bold;
                }
                body, table, td, th, div, span, p {
                    font-family: 'DejaVu Sans', sans-serif !important;
                }
            </style>
            <t t-foreach="docs" t-as="o">
                <div style="font-family: 'DejaVu Sans', sans-serif; font-size: 13px; color: #222;
                            max-width: 800px; margin: 20px auto; padding: 24px;
                            border: 1px solid #ccc;">

                    <!-- Tiêu đề -->
                    <div style="text-align: center; margin-bottom: 20px; border-bottom: 2px solid #1f3864; padding-bottom: 12px;">
                        <h2 style="margin: 0; font-size: 20px; text-transform: uppercase;
                                   letter-spacing: 2px; color: #1f3864;">PHIẾU LƯƠNG</h2>
                        <div style="font-size: 13px; color: #555; margin-top: 6px;">
                            Kỳ lương: <strong><t t-esc="o.period_display"/></strong>
                        </div>
                    </div>

                    <!-- Thông tin nhân viên -->
                    <table style="width:100%; border-collapse:collapse; margin-bottom:16px;
                                  background:#f0f4fa; border-radius:4px;">
                        <tr>
                            <td style="padding:7px 14px; width:50%;">
                                <strong>Họ và tên:</strong>
                                <span style="margin-left:6px; font-size:14px;"><t t-esc="o.employee_id.name"/></span>
                            </td>
                            <td style="padding:7px 14px; width:50%;">
                                <strong>Mã nhân viên:</strong>
                                <span style="margin-left:6px;"><t t-esc="o.employee_id.employee_code or '—'"/></span>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:7px 14px;">
                                <strong>Phòng ban:</strong>
                                <span style="margin-left:6px;"><t t-esc="o.department_id.name if o.department_id else '—'"/></span>
                            </td>
                            <td style="padding:7px 14px;">
                                <strong>Loại hợp đồng:</strong>
                                <span style="margin-left:6px;">
                                    <t t-if="o.contract_type == 'chinh-thuc'">Chính thức</t>
                                    <t t-elif="o.contract_type == 'thu-viec'">Thử việc</t>
                                    <t t-elif="o.contract_type == 'thuc-tap'">Thực tập</t>
                                    <t t-else="">—</t>
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:7px 14px;">
                                <strong>Mã phiếu:</strong>
                                <span style="margin-left:6px;"><t t-esc="o.name"/></span>
                            </td>
                            <td style="padding:7px 14px;">
                                <strong>Trạng thái:</strong>
                                <span style="margin-left:6px;">
                                    <t t-if="o.state == 'draft'">Nháp</t>
                                    <t t-elif="o.state == 'confirmed'">Đã xác nhận</t>
                                    <t t-else="">Đã thanh toán</t>
                                </span>
                            </td>
                        </tr>
                    </table>

                    <!-- Bảng lương -->
                    <table style="width:100%; border-collapse:collapse; font-size:12.5px;">
                        <thead>
                            <tr style="background:#1f3864; color:#fff;">
                                <th style="padding:8px 10px; text-align:left; width:7%;">Mã</th>
                                <th style="padding:8px 10px; text-align:left;">Khoản mục</th>
                                <th style="padding:8px 10px; text-align:right; width:18%;">Số công</th>
                                <th style="padding:8px 10px; text-align:right; width:22%;">Số tiền (VNĐ)</th>
                            </tr>
                        </thead>
                        <tbody>

                            <!-- ── I. THU NHẬP ── -->
                            <tr style="background:#dce6f1;">
                                <td colspan="4" style="padding:6px 10px; font-weight:bold; font-size:13px;">I. THU NHẬP</td>
                            </tr>
                            <tr style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L1</td>
                                <td style="padding:5px 10px;">Lương tháng (cơ bản)</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.base_salary)"/></td>
                            </tr>
                            <tr style="background:#f5f5f5;">
                                <td style="padding:5px 10px; color:#666;">L2</td>
                                <td style="padding:5px 10px;">Ngày công chuẩn</td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:.1f}'.format(o.standard_days)"/></td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                            </tr>
                            <tr style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L3</td>
                                <td style="padding:5px 10px;">Đơn giá / ngày</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.daily_rate)"/></td>
                            </tr>
                            <tr style="background:#f5f5f5;">
                                <td style="padding:5px 10px; color:#666;">L4</td>
                                <td style="padding:5px 10px;">Ngày công thực tế (X)</td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:.1f}'.format(o.worked_days)"/></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.time_salary)"/></td>
                            </tr>
                            <tr t-if="o.trial_days > 0" style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L6</td>
                                <td style="padding:5px 10px;">Ngày thử việc (TV)</td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:.1f}'.format(o.trial_days)"/></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.trial_salary)"/></td>
                            </tr>
                            <tr t-if="o.leave_days > 0" style="background:#f5f5f5;">
                                <td style="padding:5px 10px; color:#666;">L8</td>
                                <td style="padding:5px 10px;">Ngày phép / lễ / chính đáng</td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:.1f}'.format(o.leave_days)"/></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.leave_salary)"/></td>
                            </tr>
                            <tr t-if="o.compensatory_days > 0" style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L10</td>
                                <td style="padding:5px 10px;">Ngày nghỉ bù hưởng lương (NB)</td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:.1f}'.format(o.compensatory_days)"/></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.compensatory_salary)"/></td>
                            </tr>
                            <tr t-if="o.overtime_days > 0" style="background:#f5f5f5;">
                                <td style="padding:5px 10px; color:#666;">L12</td>
                                <td style="padding:5px 10px;">Ngày tăng ca (×1.5)</td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:.1f}'.format(o.overtime_days)"/></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.overtime_salary)"/></td>
                            </tr>
                            <tr t-if="o.bonus_sales > 0" style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L14</td>
                                <td style="padding:5px 10px;">Thưởng doanh số</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.bonus_sales)"/></td>
                            </tr>
                            <tr t-if="o.allowance > 0" style="background:#f5f5f5;">
                                <td style="padding:5px 10px; color:#666;">L15</td>
                                <td style="padding:5px 10px;">Phụ cấp khác</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.allowance)"/></td>
                            </tr>
                            <tr style="background:#c6efce; font-weight:bold;">
                                <td style="padding:7px 10px; color:#666;">L19</td>
                                <td style="padding:7px 10px;">Tổng thu nhập (Gross)</td>
                                <td style="padding:7px 10px; text-align:right;"></td>
                                <td style="padding:7px 10px; text-align:right; color:#276221;"><t t-esc="'{:,.0f}'.format(o.total_gross)"/></td>
                            </tr>

                            <!-- ── II. BẢO HIỂM NHÂN VIÊN ── -->
                            <tr style="background:#dce6f1;">
                                <td colspan="4" style="padding:6px 10px; font-weight:bold; font-size:13px;">II. BẢO HIỂM (Nhân viên đóng)</td>
                            </tr>
                            <tr style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L22</td>
                                <td style="padding:5px 10px;">Lương đóng bảo hiểm</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.insurance_base)"/></td>
                            </tr>
                            <tr style="background:#f5f5f5;">
                                <td style="padding:5px 10px; color:#666;">L24</td>
                                <td style="padding:5px 10px;">BHXH nhân viên (8%)</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.bhxh_employee)"/></td>
                            </tr>
                            <tr style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L25</td>
                                <td style="padding:5px 10px;">BHYT nhân viên (1.5%)</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.bhyt_employee)"/></td>
                            </tr>
                            <tr style="background:#f5f5f5;">
                                <td style="padding:5px 10px; color:#666;">L26</td>
                                <td style="padding:5px 10px;">BHTN nhân viên (1%)</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.bhtn_employee)"/></td>
                            </tr>
                            <tr style="background:#fce4d6; font-weight:bold;">
                                <td style="padding:7px 10px; color:#666;">L23</td>
                                <td style="padding:7px 10px;">Tổng khấu trừ bảo hiểm NV</td>
                                <td style="padding:7px 10px; text-align:right;"></td>
                                <td style="padding:7px 10px; text-align:right; color:#c00000;">(<t t-esc="'{:,.0f}'.format(o.total_insurance_employee)"/>)</td>
                            </tr>

                            <!-- ── III. THUẾ TNCN ── -->
                            <tr style="background:#dce6f1;">
                                <td colspan="4" style="padding:6px 10px; font-weight:bold; font-size:13px;">III. THUẾ THU NHẬP CÁ NHÂN</td>
                            </tr>
                            <tr style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L29</td>
                                <td style="padding:5px 10px;">Giảm trừ bản thân</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.personal_deduction)"/></td>
                            </tr>
                            <tr t-if="o.dependents > 0" style="background:#f5f5f5;">
                                <td style="padding:5px 10px; color:#666;">L30</td>
                                <td style="padding:5px 10px;">Giảm trừ người phụ thuộc (<t t-esc="o.dependents"/> người)</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.dependent_deduction)"/></td>
                            </tr>
                            <tr style="background:#fff;">
                                <td style="padding:5px 10px; color:#666;">L31</td>
                                <td style="padding:5px 10px;">Thu nhập tính thuế</td>
                                <td style="padding:5px 10px; text-align:right;"></td>
                                <td style="padding:5px 10px; text-align:right;"><t t-esc="'{:,.0f}'.format(o.taxable_income)"/></td>
                            </tr>
                            <tr style="background:#fce4d6; font-weight:bold;">
                                <td style="padding:7px 10px; color:#666;">L28</td>
                                <td style="padding:7px 10px;">Thuế TNCN</td>
                                <td style="padding:7px 10px; text-align:right;"></td>
                                <td style="padding:7px 10px; text-align:right; color:#c00000;">(<t t-esc="'{:,.0f}'.format(o.personal_income_tax)"/>)</td>
                            </tr>

                            <!-- ── IV. KHẤU TRỪ KHÁC ── -->
                            <t t-if="o.salary_deduction > 0 or o.advance_payment > 0 or o.company_hold > 0">
                                <tr style="background:#dce6f1;">
                                    <td colspan="4" style="padding:6px 10px; font-weight:bold; font-size:13px;">IV. KHẤU TRỪ KHÁC</td>
                                </tr>
                                <tr t-if="o.salary_deduction > 0" style="background:#fff;">
                                    <td style="padding:5px 10px; color:#666;">L17</td>
                                    <td style="padding:5px 10px;">Trừ lương khác</td>
                                    <td style="padding:5px 10px; text-align:right;"></td>
                                    <td style="padding:5px 10px; text-align:right;">(<t t-esc="'{:,.0f}'.format(o.salary_deduction)"/>)</td>
                                </tr>
                                <tr t-if="o.advance_payment > 0" style="background:#f5f5f5;">
                                    <td style="padding:5px 10px; color:#666;">L21</td>
                                    <td style="padding:5px 10px;">Tạm ứng</td>
                                    <td style="padding:5px 10px; text-align:right;"></td>
                                    <td style="padding:5px 10px; text-align:right;">(<t t-esc="'{:,.0f}'.format(o.advance_payment)"/>)</td>
                                </tr>
                                <tr t-if="o.company_hold > 0" style="background:#fff;">
                                    <td style="padding:5px 10px; color:#666;">L20</td>
                                    <td style="padding:5px 10px;">Công ty giữ lại</td>
                                    <td style="padding:5px 10px; text-align:right;"></td>
                                    <td style="padding:5px 10px; text-align:right;">(<t t-esc="'{:,.0f}'.format(o.company_hold)"/>)</td>
                                </tr>
                            </t>

                            <!-- ── THỰC NHẬN ── -->
                            <tr style="background:#1f3864; color:#fff;">
                                <td colspan="2" style="padding:10px 10px; font-size:14px; font-weight:bold;">
                                    NHÂN VIÊN THỰC NHẬN
                                </td>
                                <td style="padding:10px 10px; text-align:right; font-size:14px; font-weight:bold;"></td>
                                <td style="padding:10px 10px; text-align:right; font-size:15px; font-weight:bold;">
                                    <t t-esc="'{:,.0f}'.format(o.net_salary)"/> ₫
                                </td>
                            </tr>

                        </tbody>
                    </table>

                    <!-- Ghi chú -->
                    <t t-if="o.note">
                        <div style="margin-top:12px; padding:8px 12px; background:#fff8e1;
                                    border-left:4px solid #ffc107; font-size:12px;">
                            <strong>Ghi chú:</strong> <t t-esc="o.note"/>
                        </div>
                    </t>

                    <!-- Chữ ký -->
                    <table style="width:100%; margin-top:36px; font-size:12px; text-align:center;">
                        <tr>
                            <td style="width:33%; vertical-align:top;">
                                <div style="font-weight:bold;">NHÂN VIÊN</div>
                                <div style="color:#888; margin-top:2px; font-size:11px;">(Ký, ghi rõ họ tên)</div>
                                <div style="height:56px;"></div>
                                <div><t t-esc="o.employee_id.name"/></div>
                            </td>
                            <td style="width:33%; vertical-align:top;">
                                <div style="font-weight:bold;">KẾ TOÁN</div>
                                <div style="color:#888; margin-top:2px; font-size:11px;">(Ký, ghi rõ họ tên)</div>
                                <div style="height:56px;"></div>
                            </td>
                            <td style="width:33%; vertical-align:top;">
                                <div style="font-weight:bold;">GIÁM ĐỐC</div>
                                <div style="color:#888; margin-top:2px; font-size:11px;">(Ký, đóng dấu)</div>
                                <div style="height:56px;"></div>
                            </td>
                        </tr>
                    </table>

                </div>
            </t>
        </t>
    </template>

    <!-- ═══════════════ Report Action ═══════════════ -->
    <record id="action_report_payroll" model="ir.actions.report">
        <field name="name">Phiếu lương</field>
        <field name="model">bbsw.payroll</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bbsw_thuchi.report_payroll_template</field>
        <field name="report_file">bbsw_thuchi.report_payroll_template</field>
        <field name="binding_model_id" ref="model_bbsw_payroll"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
