              name="Đơn vị kinh doanh"
              parent="menu_thuchi_config"
              action="action_business_unit"
              sequence="20"/>

    <menuitem id="menu_payment_method"
              name="Phương thức thanh toán"
              parent="menu_thuchi_config"
              action="action_payment_method"
              sequence="30"/>

    <menuitem id="menu_thuchi_partner"
              name="Đối tác"
              parent="menu_thuchi_config"
              action="action_thuchi_partner"
              sequence="40"/>

    <menuitem id="menu_home_apps"
              name="Ứng dụng trang chủ"
              parent="menu_thuchi_config"
              action="action_home_app"
              sequence="90"/>

