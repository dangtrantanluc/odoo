<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════ Wizard Form View ═══════════════ -->
    <record id="view_payroll_generate_wizard_form" model="ir.ui.view">
        <field name="name">bbsw.payroll.generate.wizard.form</field>
        <field name="model">bbsw.payroll.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Tạo bảng lương hàng loạt">
                <sheet>
                    <field name="state" invisible="1"/>
                    <!-- Chưa tạo -->
                    <group invisible="state == 'done'">
                        <group string="Kỳ lương">
                            <field name="period_month" string="Tháng"/>
                            <field name="period_year" string="Năm"/>
                        </group>
                        <group string="Tùy chọn">
                            <field name="overwrite_existing"/>
                        </group>
                    </group>

                    <!-- Đã tạo xong -->
                    <group invisible="state != 'done'" string="Kết quả">
                        <div class="alert alert-success" role="alert" style="margin: 0 0 16px 0;">
                            <h4 style="margin:0 0 8px 0;">Hoàn tất!</h4>
                            <p style="margin:0">Đã xử lý xong bảng lương
                                <strong><field name="period_month" readonly="1" nolabel="1"/>/<field name="period_year" readonly="1" nolabel="1"/></strong>
                            </p>
                        </div>
                        <group>
                            <field name="result_created" string="Phiếu mới tạo" readonly="1"/>
                            <field name="result_updated" string="Phiếu đã tính lại" readonly="1"/>
                            <field name="result_skipped" string="Phiếu bỏ qua (đã tồn tại)" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate"
                            type="object"
                            string="Tạo bảng lương"
                            class="btn-primary"
                            invisible="state == 'done'"/>
                    <button name="action_open_payrolls"
                            type="object"
                            string="Xem bảng lương"
                            class="btn-primary"
                            invisible="state != 'done'"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═══════════════ Action ═══════════════ -->
    <record id="action_payroll_generate_wizard" model="ir.actions.act_window">
        <field name="name">Tạo bảng lương hàng loạt</field>
        <field name="res_model">bbsw.payroll.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ═══════════════ Menu ═══════════════ -->
    <menuitem id="menu_payroll_generate"
              name="Tạo lương hàng loạt"
              parent="bbsw_thuchi.menu_tinhluong_root"
              action="action_payroll_generate_wizard"
              sequence="2"/>

</odoo>
