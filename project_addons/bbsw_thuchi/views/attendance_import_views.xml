<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_import_form" model="ir.ui.view">
        <field name="name">bbsw.attendance.import.form</field>
        <field name="model">bbsw.attendance.import</field>
        <field name="arch" type="xml">
            <form string="Import chấm công">
                <sheet>
                    <group string="Kỳ chấm công">
                        <group>
                            <field name="period_month"/>
                            <field name="period_year"/>
                            <field name="overwrite"/>
                        </group>
                        <group>
                            <field name="file_data" filename="file_name" widget="binary"
                                   string="File Excel (.xlsx)"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                    </group>

                    <group string="Hướng dẫn" col="1">
                        <div class="alert alert-info" role="alert">
                            <strong>Yêu cầu file Excel (.xlsx):</strong><br/>
                            — Dòng tiêu đề phải có cột <b>Mã NV</b> (hoặc "Mã nv", "MANV")<br/>
                            — Các cột ngày là số nguyên: 1, 2, 3 ... 31<br/>
                            — Giá trị trong ô là mã chấm công:<br/><br/>
                            <table style="width:100%; font-size:12px;">
                                <tr><th>Mã</th><th>Ý nghĩa</th><th>Số công</th><th>Mã</th><th>Ý nghĩa</th><th>Số công</th></tr>
                                <tr><td><b>X</b></td><td>Ngày công chính thức</td><td>1.0</td><td><b>X/KL</b></td><td>Nửa ngày không lương</td><td>0.5</td></tr>
                                <tr><td><b>TV</b></td><td>Ngày công thử việc</td><td>1.0</td><td><b>P/KL</b></td><td>Nửa ngày phép/không lương</td><td>0.5</td></tr>
                                <tr><td><b>P</b></td><td>Phép năm</td><td>1.0</td><td><b>X/P</b></td><td>Nửa ngày phép năm</td><td>0.5</td></tr>
                                <tr><td><b>BH</b></td><td>Nghỉ chế độ BH</td><td>1.0</td><td><b>X/NB</b></td><td>Nửa ngày làm, nửa nghỉ bù</td><td>0.5</td></tr>
                                <tr><td><b>CĐ</b></td><td>Nghỉ chế độ (hiếu, hỉ)</td><td>1.0</td><td><b>NB</b></td><td>Nghỉ bù</td><td>0.0</td></tr>
                                <tr><td><b>NL</b></td><td>Nghỉ lễ, tết</td><td>1.0</td><td><b>KL</b></td><td>Nghỉ không lương</td><td>0.0</td></tr>
                                <tr><td><b>CT</b></td><td>Công tác</td><td>1.0</td><td></td><td></td><td></td></tr>
                            </table>
                            <br/>
                            <b>Lưu ý:</b> Bảng chấm công tháng giao thoa (VD: 26-31 tháng trước + 1-27 tháng này) được xử lý tự động.
                        </div>
                    </group>

                    <group string="Kết quả" invisible="not result_message">
                        <field name="result_message" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_import" model="ir.actions.act_window">
        <field name="name">Import chấm công</field>
        <field name="res_model">bbsw.attendance.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_chamcong_import"
              name="Import chấm công"
              parent="menu_chamcong_root"
              action="action_attendance_import"
              sequence="2"/>

</odoo>
