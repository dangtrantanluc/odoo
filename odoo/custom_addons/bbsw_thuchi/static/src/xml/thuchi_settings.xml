<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="bbsw_thuchi.SettingsPage">
    <div class="bbsw-settings-page">

        <!-- Header -->
        <div class="bbsw-settings-header">
            <div class="d-flex align-items-center gap-3">
                <div class="bbsw-settings-header-icon">
                    <i class="fa fa-cog fa-lg"/>
                </div>
                <div>
                    <h4 class="mb-0 fw-bold">Cài đặt hệ thống</h4>
                    <div class="text-white-50" style="font-size:13px">Quản lý danh mục, đơn vị và cấu hình Thu Chi</div>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="bbsw-settings-body">

            <!-- Nhóm: Danh mục & Tài chính -->
            <div class="bbsw-settings-section">
                <div class="bbsw-settings-section-title">
                    <i class="fa fa-sliders me-2"/>Danh mục &amp; Tài chính
                </div>
                <div class="bbsw-settings-cards">

                    <div class="bbsw-settings-card" t-on-click="() => openAction('bbsw_thuchi.action_thuchi_category')">
                        <div class="bbsw-sc-icon" style="background:#dbeafe;color:#1d4ed8">
                            <i class="fa fa-tags fa-lg"/>
                        </div>
                        <div class="bbsw-sc-body">
                            <div class="bbsw-sc-title">Danh mục</div>
                            <div class="bbsw-sc-desc">Quản lý danh mục Thu / Chi / Vay</div>
                        </div>
                        <i class="fa fa-chevron-right bbsw-sc-arrow"/>
                    </div>

                    <div class="bbsw-settings-card" t-on-click="() => openAction('bbsw_thuchi.action_payment_method')">
                        <div class="bbsw-sc-icon" style="background:#dcfce7;color:#16a34a">
                            <i class="fa fa-credit-card fa-lg"/>
                        </div>
                        <div class="bbsw-sc-body">
                            <div class="bbsw-sc-title">Phương thức thanh toán</div>
                            <div class="bbsw-sc-desc">Tiền mặt, chuyển khoản, thẻ tín dụng…</div>
                        </div>
                        <i class="fa fa-chevron-right bbsw-sc-arrow"/>
                    </div>

                </div>
            </div>

            <!-- Nhóm: Tổ chức -->
            <div class="bbsw-settings-section">
                <div class="bbsw-settings-section-title">
                    <i class="fa fa-building me-2"/>Tổ chức
                </div>
                <div class="bbsw-settings-cards">

                    <div class="bbsw-settings-card" t-on-click="() => openAction('bbsw_thuchi.action_business_unit')">
                        <div class="bbsw-sc-icon" style="background:#fef9c3;color:#ca8a04">
                            <i class="fa fa-sitemap fa-lg"/>
                        </div>
                        <div class="bbsw-sc-body">
                            <div class="bbsw-sc-title">Đơn vị kinh doanh</div>
                            <div class="bbsw-sc-desc">Quản lý các BU: BBSW, BBAC, BBSV…</div>
                        </div>
                        <i class="fa fa-chevron-right bbsw-sc-arrow"/>
                    </div>

                    <div class="bbsw-settings-card" t-on-click="() => openAction('bbsw_thuchi.action_thuchi_partner')">
                        <div class="bbsw-sc-icon" style="background:#fce7f3;color:#db2777">
                            <i class="fa fa-handshake-o fa-lg"/>
                        </div>
                        <div class="bbsw-sc-body">
                            <div class="bbsw-sc-title">Đối tác</div>
                            <div class="bbsw-sc-desc">Nhà cung cấp, khách hàng, đối tác</div>
                        </div>
                        <i class="fa fa-chevron-right bbsw-sc-arrow"/>
                    </div>

                </div>
            </div>

            <!-- Nhóm: Giao diện -->
            <div class="bbsw-settings-section">
                <div class="bbsw-settings-section-title">
                    <i class="fa fa-paint-brush me-2"/>Giao diện
                </div>
                <div class="bbsw-settings-cards">

                    <div class="bbsw-settings-card" t-on-click="() => openAction('bbsw_thuchi.action_home_app')">
                        <div class="bbsw-sc-icon" style="background:#ede9fe;color:#7c3aed">
                            <i class="fa fa-th-large fa-lg"/>
                        </div>
                        <div class="bbsw-sc-body">
                            <div class="bbsw-sc-title">Ứng dụng trang chủ</div>
                            <div class="bbsw-sc-desc">Cấu hình tile launcher trên trang chủ</div>
                        </div>
                        <i class="fa fa-chevron-right bbsw-sc-arrow"/>
                    </div>

                </div>
            </div>

            <!-- Nhóm: Hệ thống (chỉ Admin) -->
            <div class="bbsw-settings-section">
                <div class="bbsw-settings-section-title">
                    <i class="fa fa-shield me-2"/>Hệ thống
                </div>
                <div class="bbsw-settings-cards">

                    <div class="bbsw-settings-card" t-on-click="() => openAction('base_setup.action_general_configuration')">
                        <div class="bbsw-sc-icon" style="background:#fee2e2;color:#dc2626">
                            <i class="fa fa-cog fa-lg"/>
                        </div>
                        <div class="bbsw-sc-body">
                            <div class="bbsw-sc-title">Cài đặt hệ thống</div>
                            <div class="bbsw-sc-desc">Quản lý người dùng, công ty, email… (yêu cầu Admin)</div>
                        </div>
                        <i class="fa fa-chevron-right bbsw-sc-arrow"/>
                    </div>

                    <div class="bbsw-settings-card" t-on-click="() => openAction('base.action_res_users')">
                        <div class="bbsw-sc-icon" style="background:#e0f2fe;color:#0284c7">
                            <i class="fa fa-users fa-lg"/>
                        </div>
                        <div class="bbsw-sc-body">
                            <div class="bbsw-sc-title">Người dùng</div>
                            <div class="bbsw-sc-desc">Thêm, sửa, phân quyền tài khoản đăng nhập</div>
                        </div>
                        <i class="fa fa-chevron-right bbsw-sc-arrow"/>
                    </div>

                </div>
            </div>

        </div>
    </div>
</t>

</templates>
