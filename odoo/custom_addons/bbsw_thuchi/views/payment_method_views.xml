<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_payment_method_tree" model="ir.ui.view">
        <field name="name">bbsw.payment.method.tree</field>
        <field name="model">bbsw.payment.method</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="owner"/>
                <field name="account_info"/>
                <field name="opening_balance"/>
                <field name="balance"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-danger="status == 'inactive'"/>
            </tree>
        </field>
    </record>

    <record id="view_payment_method_form" model="ir.ui.view">
        <field name="name">bbsw.payment.method.form</field>
        <field name="model">bbsw.payment.method</field>
        <field name="arch" type="xml">
            <form string="Phương thức thanh toán">
                <sheet>
                    <group>
                        <group string="Thông tin">
                            <field name="code"/>
                            <field name="name"/>
                            <field name="type"/>
                            <field name="status"/>
                        </group>
                        <group string="Tài khoản">
                            <field name="owner"/>
                            <field name="account_info"/>
                            <field name="bu_name"/>
                            <field name="opening_balance"/>
                            <field name="balance"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_payment_method" model="ir.actions.act_window">
        <field name="name">Phương thức thanh toán</field>
        <field name="res_model">bbsw.payment.method</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
