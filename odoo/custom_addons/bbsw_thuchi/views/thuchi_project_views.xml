<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_thuchi_project_tree" model="ir.ui.view">
        <field name="name">bbsw.thuchi.project.tree</field>
        <field name="model">bbsw.thuchi.project</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="pm"/>
                <field name="bu_owner"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="budget"/>
                <field name="spent"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-warning="status == 'closed'"
                       decoration-danger="status == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record id="view_thuchi_project_form" model="ir.ui.view">
        <field name="name">bbsw.thuchi.project.form</field>
        <field name="model">bbsw.thuchi.project</field>
        <field name="arch" type="xml">
            <form string="Dự án">
                <sheet>
                    <group>
                        <group string="Thông tin dự án">
                            <field name="code"/>
                            <field name="name"/>
                            <field name="pm"/>
                            <field name="bu_owner"/>
                            <field name="status"/>
                        </group>
                        <group string="Thời gian &amp; Ngân sách">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="budget"/>
                            <field name="spent"/>
                        </group>
                    </group>
                    <group string="Mô tả">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Giao dịch">
                            <field name="transaction_ids" readonly="1">
                                <tree>
                                    <field name="transaction_code"/>
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="type"/>
                                    <field name="amount"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_thuchi_project" model="ir.actions.act_window">
        <field name="name">Dự án</field>
        <field name="res_model">bbsw.thuchi.project</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
