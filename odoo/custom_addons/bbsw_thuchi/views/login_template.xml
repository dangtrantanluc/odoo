<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="bbsw_login_form" name="BBSW Login Form" inherit_id="web.login" priority="20">
        <!-- Cột trái: inject trước form -->
        <xpath expr="//form[hasclass('oe_login_form')]" position="before">
            <div class="bbsw-left-panel">
                <div class="bbsw-left-logo">
                    <img src="/bbsw_thuchi/static/src/img/logo.svg" alt="BlueBolt"/>
                </div>
                <div class="bbsw-left-title">Quản Lý Thu Chi</div>
                <div class="bbsw-left-illus">
                    <img src="/bbsw_thuchi/static/src/img/finance_illustration.svg" alt=""/>
                </div>
            </div>
            <!-- Welcome header cho cột phải -->
            <div class="bbsw-right-header">
                <h3 class="bbsw-welcome-title">Welcome Back!</h3>
                <p class="bbsw-welcome-sub">Đăng nhập vào tài khoản của bạn</p>
            </div>
        </xpath>
    </template>
</odoo>
