<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════ Tree View ═══════════════ -->
    <record id="view_bbsw_attendance_tree" model="ir.ui.view">
        <field name="name">hr.attendance.bbsw.tree</field>
        <field name="model">hr.attendance</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree string="Danh sách chấm công"
                  decoration-success="color == 10"
                  decoration-danger="color == 1"
                  duplicate="false">
                <field name="employee_id" string="Nhân viên" widget="many2one_avatar_user"/>
                <field name="check_in" string="Giờ vào"/>
                <field name="check_out" string="Giờ ra" options="{}"/>
                <field name="worked_hours" string="Số giờ làm" widget="float_time"/>
                <field name="overtime_hours" string="Làm thêm giờ" optional="show" widget="float_time"/>
                <field name="color" column_invisible="1"/>
                <field name="in_mode" optional="hidden"/>
                <field name="out_mode" optional="hidden"/>
                <field name="in_country_name" optional="hidden"/>
                <field name="out_country_name" optional="hidden"/>
                <field name="in_city" optional="hidden"/>
                <field name="out_city" optional="hidden"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════ Form View ═══════════════ -->
    <record id="view_bbsw_attendance_form" model="ir.ui.view">
        <field name="name">hr.attendance.bbsw.form</field>
        <field name="model">hr.attendance</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Chấm công nhân viên" duplicate="false">
                <sheet>
                    <group>
                        <group colspan="2">
                            <group col="1">
                                <field name="employee_id" string="Nhân viên" widget="many2one_avatar_user"/>
                                <field name="check_in" string="Giờ vào" options="{'rounding': 0}"/>
                                <field name="check_out" string="Giờ ra" options="{'rounding': 0}"/>
                            </group>
                            <group col="2">
                                <field name="worked_hours" string="Số giờ làm" widget="float_time"/>
                                <field name="overtime_hours" string="Làm thêm giờ" widget="float_time"/>
                            </group>
                        </group>
                        <separator string="Chi tiết vào ca"/>
                        <group colspan="2">
                            <group>
                                <group>
                                    <field name="in_mode" string="Phương thức"/>
                                    <field name="in_ip_address" string="Địa chỉ IP" invisible="in_mode == 'manual'"/>
                                    <field name="in_browser" string="Trình duyệt" invisible="in_mode == 'manual'"/>
                                </group>
                            </group>
                            <group invisible="in_mode == 'manual'">
                                <label for="in_country_name" string="Vị trí"/>
                                <div class="o_row" name="in_location_info">
                                    <span><field name="in_country_name"/></span>
                                    <span><field name="in_city" invisible="in_city == 'Unknown'" nolabel="1"/></span>
                                </div>
                                <label for="in_latitude" string="Tọa độ GPS"/>
                                <div>
                                    <div class="o_row">
                                        <span><field name="in_latitude"/></span>,
                                        <span><field name="in_longitude" nolabel="1"/></span>
                                    </div>
                                    <button name="action_in_attendance_maps" type="object"
                                            class="btn btn-link ps-0 pt-0 pb-2"
                                            icon="oi-arrow-right" string="Xem bản đồ" colspan="2"/>
                                </div>
                            </group>
                        </group>
                        <separator string="Chi tiết ra ca" invisible="not check_out"/>
                        <group colspan="2" invisible="not check_out">
                            <group>
                                <group>
                                    <field name="out_mode" string="Phương thức"/>
                                    <field name="out_ip_address" string="Địa chỉ IP" invisible="in_mode == 'manual'"/>
                                    <field name="out_browser" string="Trình duyệt" invisible="in_mode == 'manual'"/>
                                </group>
                            </group>
                            <group invisible="out_mode == 'manual'">
                                <label for="out_country_name" string="Vị trí"/>
                                <div class="o_row" name="out_location_info">
                                    <span><field name="out_country_name"/></span>
                                    <span><field name="out_city" invisible="out_city == 'Unknown'" nolabel="1"/></span>
                                </div>
                                <label for="out_latitude" string="Tọa độ GPS"/>
                                <div>
                                    <div class="o_row">
                                        <span><field name="out_latitude"/></span>,
                                        <span><field name="out_longitude" nolabel="1"/></span>
                                    </div>
                                    <button name="action_out_attendance_maps" type="object"
                                            class="btn btn-link ps-0 pt-0 pb-2"
                                            icon="oi-arrow-right" string="Xem bản đồ" colspan="2"/>
                                </div>
                            </group>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══════════════ Search View ═══════════════ -->
    <record id="view_bbsw_attendance_search" model="ir.ui.view">
        <field name="name">hr.attendance.bbsw.search</field>
        <field name="model">hr.attendance</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm chấm công">
                <field name="employee_id" string="Nhân viên"/>
                <field name="department_id" string="Phòng ban" operator="child_of"/>
                <field name="check_in" string="Giờ vào"/>
                <filter string="Chấm công của tôi" name="myattendances"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="Nhóm của tôi" name="myteam"
                        domain="[('employee_id.parent_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Đang làm việc" name="nocheckout"
                        domain="[('check_out', '=', False)]"/>
                <filter string="Có lỗi" name="errors"
                        domain="['|', ('worked_hours', '&gt;=', 16), '&amp;', ('check_out', '=', False), ('check_in', '&lt;=', (context_today() - datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Theo giờ vào" name="check_in_filter" date="check_in"/>
                <filter string="7 ngày gần đây" name="last_week"
                        domain="[('check_in', '&gt;=', (context_today() + datetime.timedelta(days=-7)))]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Giờ vào" name="groupby_name" context="{'group_by': 'check_in:week'}"/>
                    <filter string="Nhân viên" name="employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Phòng ban" name="groupby_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Giờ ra" name="groupby_check_out" context="{'group_by': 'check_out'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════ Actions ═══════════════ -->
    <record id="action_bbsw_attendance" model="ir.actions.act_window">
        <field name="name">Chấm Công</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <!-- ═══════════════ Menu ═══════════════ -->
    <menuitem id="menu_chamcong_root"
              name="Chấm Công"
              web_icon="hr_attendance,static/description/icon.png"
              sequence="12"/>

    <menuitem id="menu_chamcong_list"
              name="Danh sách chấm công"
              parent="menu_chamcong_root"
              action="action_bbsw_attendance"
              sequence="1"/>


</odoo>
