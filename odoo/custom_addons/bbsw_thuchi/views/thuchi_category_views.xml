<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════ Tree View ═══════════════ -->
    <record id="view_thuchi_category_tree" model="ir.ui.view">
        <field name="name">bbsw.thuchi.category.tree</field>
        <field name="model">bbsw.thuchi.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="description"/>
                <field name="record_count"/>
                <field name="active" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════ Form View ═══════════════ -->
    <record id="view_thuchi_category_form" model="ir.ui.view">
        <field name="name">bbsw.thuchi.category.form</field>
        <field name="model">bbsw.thuchi.category</field>
        <field name="arch" type="xml">
            <form string="Danh mục Thu Chi">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="record_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════ Action ═══════════════ -->
    <record id="action_thuchi_category" model="ir.actions.act_window">
        <field name="name">Danh mục</field>
        <field name="res_model">bbsw.thuchi.category</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
