<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_business_unit_tree" model="ir.ui.view">
        <field name="name">bbsw.business.unit.tree</field>
        <field name="model">bbsw.business.unit</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="leader_name"/>
                <field name="staff_count"/>
                <field name="start_date"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-danger="status == 'inactive'"/>
            </tree>
        </field>
    </record>

    <record id="view_business_unit_form" model="ir.ui.view">
        <field name="name">bbsw.business.unit.form</field>
        <field name="model">bbsw.business.unit</field>
        <field name="arch" type="xml">
            <form string="Đơn vị kinh doanh">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="leader_name"/>
                        </group>
                        <group>
                            <field name="staff_count"/>
                            <field name="start_date"/>
                            <field name="status"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_business_unit" model="ir.actions.act_window">
        <field name="name">Đơn vị kinh doanh</field>
        <field name="res_model">bbsw.business.unit</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
