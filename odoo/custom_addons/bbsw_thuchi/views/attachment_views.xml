<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree view cho ir.attachment với nút xem file -->
    <record id="view_attachment_thuchi_tree" model="ir.ui.view">
        <field name="name">ir.attachment.thuchi.tree</field>
        <field name="model">ir.attachment</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <tree string="Chứng từ đính kèm" create="false" delete="false" edit="false">
                <field name="name" string="Tên tài liệu"/>
                <field name="mimetype" string="Loại file"/>
                <field name="file_size" string="Dung lượng (bytes)"/>
                <field name="create_date" string="Ngày tải lên"/>
                <button name="action_preview" string="👁 Xem" type="object" class="btn btn-sm btn-primary"/>
            </tree>
        </field>
    </record>
</odoo>
