<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="bb_project_management.AiChat">
    <div class="bb_ai_wrapper">

        <!-- ── Chat Panel ───────────────────────────────────────── -->
        <div t-if="state.open" class="bb_ai_panel">

            <!-- Header -->
            <div class="bb_ai_header">
                <div class="bb_ai_header_info">
                    <div class="bb_ai_avatar_small">
                        <i class="fa fa-robot"/>
                    </div>
                    <div>
                        <div class="bb_ai_title">BB AI Assistant</div>
                        <div class="bb_ai_subtitle">
                            <span t-attf-class="bb_ai_dot {{state.thinking ? 'thinking' : 'online'}}"/>
                            <t t-esc="state.thinking ? 'Đang xử lý...' : 'Trực tuyến'"/>
                        </div>
                    </div>
                </div>
                <div class="bb_ai_header_btns">
                    <button class="bb_ai_icon_btn" t-on-click="clearHistory" title="Cuộc hội thoại mới">
                        <i class="fa fa-refresh"/>
                    </button>
                    <button class="bb_ai_icon_btn" t-on-click="toggleChat" title="Đóng">
                        <i class="fa fa-times"/>
                    </button>
                </div>
            </div>

            <!-- Messages -->
            <div class="bb_ai_messages" t-ref="messages">
                <t t-foreach="state.messages" t-as="msg" t-key="msg_index">
                    <div t-attf-class="bb_ai_row {{msg.role}}">
                        <t t-if="msg.role === 'assistant'">
                            <div class="bb_ai_row_avatar">
                                <i class="fa fa-robot"/>
                            </div>
                        </t>
                        <div t-attf-class="bb_ai_bubble {{msg.role}} {{msg.error ? 'error' : ''}}"
                             t-out="msg.html || msg.content"/>
                        <t t-if="msg.role === 'user'">
                            <div class="bb_ai_row_avatar user">
                                <i class="fa fa-user"/>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- Thinking animation -->
                <t t-if="state.thinking">
                    <div class="bb_ai_row assistant">
                        <div class="bb_ai_row_avatar">
                            <i class="fa fa-robot"/>
                        </div>
                        <div class="bb_ai_bubble assistant bb_ai_typing">
                            <span class="bb_typing_dot"/>
                            <span class="bb_typing_dot"/>
                            <span class="bb_typing_dot"/>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Input Area -->
            <div class="bb_ai_input_wrap">
                <textarea
                    class="bb_ai_textarea"
                    placeholder="Hỏi về dự án, task, ngân sách, deadline..."
                    rows="1"
                    t-model="state.input"
                    t-on-keydown="onKeyDown"
                />
                <button
                    class="bb_ai_send"
                    t-on-click="sendMessage"
                    t-att-disabled="state.thinking || !state.input.trim()"
                >
                    <i class="fa fa-paper-plane"/>
                </button>
            </div>

        </div>

        <!-- ── Toggle Button ────────────────────────────────────── -->
        <button class="bb_ai_fab" t-on-click="toggleChat">
            <t t-if="!state.open">
                <i class="fa fa-comments"/>
                <span class="bb_ai_fab_label">AI</span>
            </t>
            <t t-else="">
                <i class="fa fa-times"/>
            </t>
        </button>

    </div>
</t>

</templates>
