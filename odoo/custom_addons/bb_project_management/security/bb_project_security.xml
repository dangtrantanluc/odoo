<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ───────────────────────────── -->
        <record id="group_bb_pm_admin" model="res.groups">
            <field name="name">BB PM / Administrator</field>
            <field name="category_id" ref="base.module_category_project"/>
            <field name="comment">Full access to all project management data; can approve/reject backlogs.</field>
        </record>

        <record id="group_bb_pm_manager" model="res.groups">
            <field name="name">BB PM / Project Manager</field>
            <field name="category_id" ref="base.module_category_project"/>
            <field name="comment">Can create/edit/archive projects, tasks and manage team members.</field>
        </record>

        <record id="group_bb_pm_member" model="res.groups">
            <field name="name">BB PM / Member</field>
            <field name="category_id" ref="base.module_category_project"/>
            <field name="comment">Can log work (backlogs) on tasks assigned to them; can update task status.</field>
        </record>

        <record id="group_bb_pm_viewer" model="res.groups">
            <field name="name">BB PM / Viewer</field>
            <field name="category_id" ref="base.module_category_project"/>
            <field name="comment">Read-only access to projects, tasks and backlogs.</field>
        </record>

        <record id="rule_bb_project_multi_company" model="ir.rule">
            <field name="name">Project Multi-Company Rule</field>
            <field name="model_id" ref="model_bb_project"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_bb_project_task_multi_company" model="ir.rule">
            <field name="name">Task Multi-Company Rule</field>
            <field name="model_id" ref="model_bb_project_task"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_bb_project_backlog_multi_company" model="ir.rule">
            <field name="name">Backlog Multi-Company Rule</field>
            <field name="model_id" ref="model_bb_project_backlog"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
        <!-- ── Record Rules ─────────────────────────────── -->

        <!-- Members can only edit their own backlogs if PENDING -->
        <record id="rule_backlog_member_own" model="ir.rule">
            <field name="name">Backlog: Members can only see backlogs of their projects</field>
            <field name="model_id" ref="bb_project_management.model_bb_project_backlog"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_bb_pm_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Managers and Admins can see all backlogs -->
        <record id="rule_backlog_manager_all" model="ir.rule">
            <field name="name">Backlog: Managers/Admins see all</field>
            <field name="model_id" ref="bb_project_management.model_bb_project_backlog"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bb_pm_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Project: Admins can see all projects -->
        <record id="rule_project_admin_all" model="ir.rule">
            <field name="name">Project: Admins see all</field>
            <field name="model_id" ref="bb_project_management.model_bb_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bb_pm_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Project: Managers can see all projects -->
        <record id="rule_project_manager_all" model="ir.rule">
            <field name="name">Project: Managers see all</field>
            <field name="model_id" ref="bb_project_management.model_bb_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bb_pm_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Project: Members can see their own projects -->
        <record id="rule_project_member_own" model="ir.rule">
            <field name="name">Project: Members can see their own projects</field>
            <field name="model_id" ref="bb_project_management.model_bb_project"/>
            <field name="domain_force">[('owner_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_bb_pm_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Project: Viewers can see all projects -->
        <record id="rule_project_viewer_all" model="ir.rule">
            <field name="name">Project: Viewers see all</field>
            <field name="model_id" ref="bb_project_management.model_bb_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_bb_pm_viewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
