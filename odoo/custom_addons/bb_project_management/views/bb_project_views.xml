<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ──────────────── PROJECT SEARCH ──────────────── -->
    <record id="view_bb_project_search" model="ir.ui.view">
        <field name="name">bb.project.search</field>
        <field name="model">bb.project</field>
        <field name="arch" type="xml">
            <search string="Search Projects">
                <field name="name" string="Project"/>
                <field name="owner_id"/>
                <field name="tag_ids"/>
                <filter name="my_projects" string="My Projects" domain="[('owner_id', '=', uid)]"/>
                <separator/>
                <filter name="planned" string="Planned" domain="[('status', '=', 'planned')]"/>
                <filter name="in_progress" string="In Progress" domain="[('status', '=', 'in_progress')]"/>
                <filter name="on_hold" string="On Hold" domain="[('status', '=', 'on_hold')]"/>
                <filter name="completed" string="Completed" domain="[('status', '=', 'completed')]"/>
                <separator/>
                <filter name="critical" string="Critical Priority" domain="[('priority', '=', 'critical')]"/>
                <filter name="high" string="High Priority" domain="[('priority', '=', 'high')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_priority" string="Priority" context="{'group_by': 'priority'}"/>
                    <filter name="group_owner" string="Owner" context="{'group_by': 'owner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ──────────────── PROJECT LIST ──────────────── -->
    <record id="view_bb_project_list" model="ir.ui.view">
        <field name="name">bb.project.tree</field>
        <field name="model">bb.project</field>
        <field name="arch" type="xml">
            <tree string="Projects"
                  decoration-success="status == 'completed'"
                  decoration-muted="status == 'cancelled'"
                  decoration-warning="status == 'on_hold'"
                  decoration-info="status == 'in_progress'">
                <field name="name"/>
                <field name="code"/>
                <field name="customer_id"/>
                <field name="owner_id" widget="many2one_avatar_user"/>
                <field name="start_date"/>
                <field name="end_date" decoration-danger="end_date and end_date &lt; context_today() and status not in ('completed','cancelled')"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'completed'"
                       decoration-warning="status == 'on_hold'"
                       decoration-danger="status == 'cancelled'"
                       decoration-info="status == 'in_progress'"
                       decoration-muted="status == 'planned'"/>
                <field name="priority" widget="priority"/>
                <field name="budget"/>
                <field name="estimated_total_cost"/>
                <field name="total_cost"/>
                <field name="currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ──────────────── PROJECT KANBAN ──────────────── -->
    <record id="view_bb_project_kanban" model="ir.ui.view">
        <field name="name">bb.project.kanban</field>
        <field name="model">bb.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="name"/>
                <field name="status"/>
                <field name="priority"/>
                <field name="owner_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="budget"/>
                <field name="total_cost"/>
                <field name="budget_remaining"/>
                <field name="task_count"/>
                <field name="member_count"/>
                <field name="currency_id"/>
                <field name="tag_ids"/>
                <field name="customer_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                        <span t-if="record.code.raw_value" class="text-muted small ms-1">
                                            [<field name="code"/>]
                                        </span>
                                    </div>
                                    <span class="badge"
                                          t-attf-class="badge #{record.priority.raw_value == 'critical' ? 'text-bg-danger' : record.priority.raw_value == 'high' ? 'text-bg-warning' : record.priority.raw_value == 'medium' ? 'text-bg-info' : 'text-bg-secondary'}">
                                        <field name="priority"/>
                                    </span>
                                </div>
                                <div class="mt-1">
                                    <field name="owner_id" widget="many2one_avatar_user"/>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left small text-muted">
                                        <i class="fa fa-tasks"/> <field name="task_count"/> tasks
                                        &amp;nbsp;·&amp;nbsp;
                                        <i class="fa fa-users"/> <field name="member_count"/> members
                                    </div>
                                </div>
                                <div class="mt-2 small">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">Budget</span>
                                        <strong><field name="budget" widget="monetary"/></strong>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">Spent</span>
                                        <strong><field name="total_cost" widget="monetary"/></strong>
                                    </div>
                                    <div t-if="record.budget.raw_value" class="progress mt-1" style="height: 6px;">
                                        <div class="progress-bar"
                                             t-attf-style="width: #{Math.min(100, record.budget.raw_value ? Math.round(record.total_cost.raw_value / record.budget.raw_value * 100) : 0)}%;"
                                             t-attf-class="progress-bar #{record.total_cost.raw_value > record.budget.raw_value ? 'bg-danger' : 'bg-success'}"/>
                                    </div>
                                </div>
                                <div t-if="record.customer_id.raw_value" class="mt-2 d-flex align-items-center">
                                    <div class="oe_kanban_avatar me-2" style="width: 24px; height: 24px; display: inline-block;">
                                        <img t-att-src="kanban_image('res.partner', 'avatar_128', record.customer_id.raw_value)" class="rounded-circle w-100 h-100" alt="Customer"/>
                                    </div>
                                    <span class="text-truncate" style="max-width: 150px; font-weight: 500;">
                                        <a type="object" name="action_open_customer" class="text-decoration-none">
                                            <field name="customer_id"/>
                                        </a>
                                    </span>
                                </div>
                                <div t-if="record.tag_ids.raw_value.length" class="mt-1">
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ──────────────── PROJECT FORM ──────────────── -->
    <record id="view_bb_project_form" model="ir.ui.view">
        <field name="name">bb.project.form</field>
        <field name="model">bb.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <header>
                    <button name="action_set_in_progress" string="Start Project" type="object"
                            class="btn-primary" invisible="status != 'planned'"/>
                    <button name="action_set_on_hold" string="Put On Hold" type="object"
                            invisible="status not in ('planned','in_progress')"/>
                    <button name="action_set_completed" string="Mark Completed" type="object"
                            class="btn-success" invisible="status not in ('in_progress','on_hold')"/>
                    <button name="action_set_cancelled" string="Cancel" type="object"
                            invisible="status in ('completed','cancelled')"/>
                    <button name="action_reopen" string="Reopen" type="object"
                            invisible="status not in ('completed','cancelled','on_hold')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="planned,in_progress,on_hold,completed"/>
                </header>
                <sheet>
                    <!-- ── Backlog Summary Panel ── -->
                    <div class="alert alert-info mb-0 pb-2 pt-2" role="status"
                         invisible="scope_count == 0"
                         style="border-left: 4px solid #667eea; background: #f0f4ff;">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <strong><i class="fa fa-list-alt me-1"/> Backlog</strong>
                            </div>
                            <div class="col-auto">
                                <span class="text-muted">Items:</span>
                                <strong><field name="scope_count" class="d-inline"/></strong>
                            </div>
                            <div class="col-auto">
                                <span class="text-muted">Est. Hours:</span>
                                <strong><field name="estimated_total_hours" class="d-inline"/></strong>
                            </div>
                            <div class="col-auto">
                                <span class="text-muted">Est. Cost:</span>
                                <strong><field name="estimated_total_cost" widget="monetary" class="d-inline"/></strong>
                                <field name="currency_id" invisible="1"/>
                            </div>
                            <div class="col-auto">
                                <span class="text-muted">Actual:</span>
                                <strong><field name="total_cost" widget="monetary" class="d-inline"/></strong>
                            </div>
                            <div class="col">
                                <span class="text-muted me-1">Task Coverage:</span>
                                <field name="estimation_progress" widget="progressbar"
                                       options="{'overflow_class': 'bg-success'}"/>
                            </div>
                        </div>
                    </div>

                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_scope" type="object" class="oe_stat_button" icon="fa-list-alt">
                            <field name="scope_count" widget="statinfo" string="Backlog"/>
                        </button>
                        <button name="action_view_tasks" type="object" class="oe_stat_button" icon="fa-tasks">
                            <field name="task_count" widget="statinfo" string="Tasks"/>
                        </button>
                        <button name="%(action_bb_project_member)d" type="action"
                                class="oe_stat_button" icon="fa-users"
                                context="{'default_project_id': active_id}">
                            <field name="member_count" widget="statinfo" string="Members"/>
                        </button>
                        <button name="action_view_backlogs" type="object" class="oe_stat_button" icon="fa-clock-o">
                            <field name="backlog_count" widget="statinfo" string="Work Logs"/>
                        </button>
                        <button name="action_view_milestones" type="object" class="oe_stat_button" icon="fa-flag">
                            <field name="milestone_count" widget="statinfo" string="Milestones"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Project Name..."/>
                        </h1>
                        <h4 class="text-muted">
                            <field name="code" placeholder="PRJ-001"/>
                        </h4>
                    </div>
                    <group>
                        <group string="Project Details">
                            <field name="owner_id" widget="many2one_avatar_user"/>
                            <field name="account_manager_id" widget="many2one_avatar_user"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="priority" widget="priority"/>
                            <field name="customer_id" widget="many2one_avatar"
                                   options="{'no_create': False, 'no_quick_create': False}"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                        <group string="Financial">
                            <field name="budget"/>
                            <field name="estimated_total_hours" readonly="1"/>
                            <field name="estimated_total_cost" readonly="1"/>
                            <field name="total_cost" readonly="1"/>
                            <field name="budget_remaining" readonly="1"
                                   decoration-danger="budget_remaining &lt; 0"/>
                            <field name="total_hours" readonly="1"/>
                            <field name="currency_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Project description and objectives..."/>
                        </page>
                        <page string="Backlog" name="scope">
                            <field name="scope_ids" context="{'default_project_id': active_id}">
                                <tree editable="bottom" open_form_view="1"
                                      decoration-success="task_id != False"
                                      decoration-muted="task_id == False and estimated_hours == 0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="milestone_id" domain="[('project_id', '=', parent.id)]"
                                           optional="show"/>
                                    <field name="assignee_id" widget="many2one_avatar_user"/>
                                    <field name="estimated_hours" sum="Total Hours"/>
                                    <field name="estimated_rate"/>
                                    <field name="estimated_cost" readonly="1" sum="Total Cost"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="description" optional="hide"/>
                                    <field name="task_id" readonly="1" optional="show"/>
                                    <button name="action_create_task" string="Create Task" type="object"
                                            icon="fa-plus-circle"
                                            invisible="task_id != False"
                                            groups="bb_project_management.group_bb_pm_manager"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Milestones" name="milestones">
                            <field name="milestone_ids" context="{'default_project_id': active_id}">
                                <tree editable="bottom"
                                      decoration-success="status == 'done'"
                                      decoration-warning="status == 'in_progress'">
                                    <field name="name"/>
                                    <field name="due_date" decoration-danger="due_date and due_date &lt; context_today() and status not in ('done','cancelled')"/>
                                    <field name="estimated_hours" readonly="1" sum="Total Hours"/>
                                    <field name="estimated_cost" readonly="1" sum="Total Cost"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="task_count"/>
                                    <field name="done_count"/>
                                    <field name="completion_pct" widget="progressbar"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'done'"
                                           decoration-warning="status == 'in_progress'"
                                           decoration-muted="status in ('draft','cancelled')"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Tasks" name="tasks">
                            <field name="task_ids" context="{'default_project_id': active_id}">
                                <tree editable="bottom" multi_edit="1" decoration-success="status == 'done'"
                                      decoration-info="status == 'review'">
                                    <field name="name"/>
                                    <field name="project_id" column_invisible="1"/>
                                    <field name="assignee_id" widget="many2one_avatar_user"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="deadline"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'done'"
                                           decoration-info="status == 'review'"
                                           decoration-warning="status == 'in_progress'"
                                           decoration-muted="status == 'todo'"/>
                                    <field name="total_hours"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Work Logs" name="backlogs">
                            <field name="worklog_ids" readonly="1">
                                <tree decoration-success="status == 'approved'"
                                      decoration-danger="status == 'rejected'"
                                      decoration-warning="status == 'pending'"
                                      open_form_view="1">
                                    <field name="work_date"/>
                                    <field name="task_id"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                    <field name="hours" sum="Total Hours"/>
                                    <field name="cost_per_hour_snapshot"/>
                                    <field name="total_cost_snapshot" sum="Total Cost"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="description" optional="show"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'approved'"
                                           decoration-danger="status == 'rejected'"
                                           decoration-warning="status == 'pending'"/>
                                    <field name="approver_id"/>
                                    <button name="action_approve" string="" type="object" icon="fa-check"
                                            invisible="status != 'pending'"
                                            groups="bb_project_management.group_bb_pm_admin"/>
                                    <button name="action_reject" string="" type="object" icon="fa-times"
                                            invisible="status != 'pending'"
                                            groups="bb_project_management.group_bb_pm_admin"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Team Members" name="members">
                            <field name="member_ids" context="{'default_project_id': active_id}">
                                <tree editable="bottom">
                                    <field name="user_id"/>
                                    <field name="role"/>
                                    <field name="current_rate"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="joined_at"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Project Actions -->
    <record id="action_bb_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">bb.project</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <record id="action_bb_project_my" model="ir.actions.act_window">
        <field name="name">My Projects</field>
        <field name="res_model">bb.project</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('owner_id', '=', uid)]</field>
        <field name="context">{'search_default_my_projects': 1}</field>
    </record>

</odoo>
