<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Member Rate inline list (used in member form) -->
    <record id="view_bb_project_member_rate_list_inline" model="ir.ui.view">
        <field name="name">bb.project.member.rate.tree.inline</field>
        <field name="model">bb.project.member.rate</field>
        <field name="arch" type="xml">
            <tree string="Rate History" editable="bottom">
                <field name="cost_per_hour"/>
                <field name="currency_id" invisible="1"/>
                <field name="effective_from"/>
                <field name="effective_to"/>
            </tree>
        </field>
    </record>

    <!-- Member List (standalone) -->
    <record id="view_bb_project_member_list" model="ir.ui.view">
        <field name="name">bb.project.member.tree</field>
        <field name="model">bb.project.member</field>
        <field name="arch" type="xml">
            <tree string="Team Members" editable="bottom" multi_edit="1">
                <field name="project_id"/>
                <field name="user_id"/>
                <field name="role"/>
                <field name="current_rate"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="joined_at"/>
            </tree>
        </field>
    </record>

    <!-- Member inline list (inside project form) -->
    <record id="view_bb_project_member_list_inline" model="ir.ui.view">
        <field name="name">bb.project.member.tree.inline</field>
        <field name="model">bb.project.member</field>
        <field name="arch" type="xml">
            <tree string="Team Members" editable="bottom">
                <field name="user_id"/>
                <field name="role"/>
                <field name="current_rate"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="joined_at"/>
            </tree>
        </field>
    </record>

    <!-- Member Form -->
    <record id="view_bb_project_member_form" model="ir.ui.view">
        <field name="name">bb.project.member.form</field>
        <field name="model">bb.project.member</field>
        <field name="arch" type="xml">
            <form string="Project Member">
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="user_id"/>
                            <field name="role"/>
                        </group>
                        <group>
                            <field name="current_rate"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="joined_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rate History" name="rates">
                            <field name="rate_ids" widget="one2many" mode="list">
                                <tree editable="bottom">
                                    <field name="cost_per_hour"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="effective_from"/>
                                    <field name="effective_to"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Member Action -->
    <record id="action_bb_project_member" model="ir.actions.act_window">
        <field name="name">Team Members</field>
        <field name="res_model">bb.project.member</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
