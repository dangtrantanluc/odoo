<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Task List -->
    <record id="view_bb_project_task_list" model="ir.ui.view">
        <field name="name">bb.project.task.tree</field>
        <field name="model">bb.project.task</field>
        <field name="arch" type="xml">
            <tree string="Tasks" editable="bottom" multi_edit="1"
                  decoration-success="status == 'done'"
                  decoration-info="status == 'review'"
                  decoration-warning="status == 'in_progress'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="assignee_id" widget="many2one_avatar_user"/>
                <field name="priority" widget="priority"/>
                <field name="milestone_id"/>
                <field name="end_at" decoration-danger="end_at and end_at &lt; context_today() and status != 'done'"/>
                <field name="days_remaining"
                       decoration-danger="days_remaining &lt; 0 and status != 'done'"
                       decoration-warning="days_remaining &lt;= 3 and days_remaining &gt;= 0 and status != 'done'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'done'"
                       decoration-info="status == 'review'"
                       decoration-warning="status == 'in_progress'"
                       decoration-muted="status == 'todo'"/>
                <field name="total_hours"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
            </tree>
        </field>
    </record>

    <!-- Task Kanban -->
    <record id="view_bb_project_task_kanban" model="ir.ui.view">
        <field name="name">bb.project.task.kanban</field>
        <field name="model">bb.project.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="name"/>
                <field name="status"/>
                <field name="priority"/>
                <field name="assignee_id"/>
                <field name="deadline"/>
                <field name="total_hours"/>
                <field name="tag_ids"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <span class="badge"
                                          t-attf-class="badge #{record.priority.raw_value == 'critical' ? 'text-bg-danger' : record.priority.raw_value == 'high' ? 'text-bg-warning' : record.priority.raw_value == 'medium' ? 'text-bg-info' : 'text-bg-secondary'}">
                                        <field name="priority"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="assignee_id" widget="many2one_avatar_user"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <span t-if="record.deadline.raw_value" class="text-muted small">
                                            <i class="fa fa-calendar"/> <field name="deadline"/>
                                        </span>
                                        <span class="ms-2 text-muted small">
                                            <i class="fa fa-clock-o"/> <field name="total_hours"/>h
                                        </span>
                                    </div>
                                </div>
                                <div t-if="record.tag_ids.raw_value.length" class="mt-1">
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Task Form -->
    <record id="view_bb_project_task_form" model="ir.ui.view">
        <field name="name">bb.project.task.form</field>
        <field name="model">bb.project.task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <header>
                    <button name="action_set_in_progress" string="Start" type="object"
                            class="btn-primary" invisible="status != 'todo'"/>
                    <button name="action_set_review" string="Send to Review" type="object"
                            class="btn-warning" invisible="status != 'in_progress'"/>
                    <button name="action_set_done" string="Mark Done" type="object"
                            class="btn-success" invisible="status not in ('in_progress', 'review')"/>
                    <button name="action_set_in_progress" string="Reopen" type="object"
                            invisible="status != 'done'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="todo,in_progress,review,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Task Title..."/></h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="project_id"/>
                            <field name="assignee_id" widget="many2one_avatar_user"/>
                            <field name="milestone_id" domain="[('project_id', '=', project_id)]"/>
                            <field name="end_at"/>
                            <field name="days_remaining"/>
                            <field name="priority" widget="priority"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                        <group string="Time &amp; Cost">
                            <field name="total_hours"/>
                            <field name="total_cost"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="backlog_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Task description..."/>
                        </page>
                        <page string="Result &amp; Issues" name="result">
                            <group>
                                <field name="result" placeholder="What was delivered / accomplished?" nolabel="1"/>
                            </group>
                            <group>
                                <field name="issues" placeholder="Any blockers or issues encountered?" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Work Logs" name="backlogs">
                            <field name="backlog_ids" context="{'default_task_id': active_id}"
                                   widget="one2many">
                                <tree editable="bottom"
                                      decoration-success="status == 'approved'"
                                      decoration-danger="status == 'rejected'">
                                    <field name="work_date"/>
                                    <field name="user_id"/>
                                    <field name="hours"/>
                                    <field name="cost_per_hour_snapshot" readonly="1"/>
                                    <field name="total_cost_snapshot" readonly="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="description" optional="hide"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'approved'"
                                           decoration-danger="status == 'rejected'"
                                           decoration-warning="status == 'pending'"/>
                                    <button name="action_approve" string="" type="object" icon="fa-check"
                                            invisible="status != 'pending'"
                                            groups="bb_project_management.group_bb_pm_admin"/>
                                    <button name="action_reject" string="" type="object" icon="fa-times"
                                            invisible="status != 'pending'"
                                            groups="bb_project_management.group_bb_pm_admin"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Task Search -->
    <record id="view_bb_project_task_search" model="ir.ui.view">
        <field name="name">bb.project.task.search</field>
        <field name="model">bb.project.task</field>
        <field name="arch" type="xml">
            <search string="Search Tasks">
                <field name="name" string="Task"/>
                <field name="project_id"/>
                <field name="assignee_id"/>
                <filter name="my_tasks" string="My Tasks" domain="[('assignee_id', '=', uid)]"/>
                <separator/>
                <filter name="todo" string="To Do" domain="[('status', '=', 'todo')]"/>
                <filter name="in_progress" string="In Progress" domain="[('status', '=', 'in_progress')]"/>
                <filter name="review" string="In Review" domain="[('status', '=', 'review')]"/>
                <filter name="done" string="Done" domain="[('status', '=', 'done')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_assignee" string="Assignee" context="{'group_by': 'assignee_id'}"/>
                    <filter name="group_priority" string="Priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Task Action (all tasks) -->
    <record id="action_bb_project_task" model="ir.actions.act_window">
        <field name="name">All Tasks</field>
        <field name="res_model">bb.project.task</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Task Action (my tasks) -->
    <record id="action_bb_project_task_my" model="ir.actions.act_window">
        <field name="name">My Tasks</field>
        <field name="res_model">bb.project.task</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('assignee_id', '=', uid)]</field>
        <field name="context">{'search_default_assignee_id': uid}</field>
    </record>

</odoo>
