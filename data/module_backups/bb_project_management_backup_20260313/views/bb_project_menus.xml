<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Root Menu ──────────────────────────────── -->
    <menuitem id="menu_bb_project_root"
              name="BB Project"
              sequence="10"
              web_icon="bb_project_management,static/src/img/icon.png"/>

    <!-- ── Dashboard ─────────────────────────── -->
    <menuitem id="menu_bb_project_dashboard"
              name="Dashboard"
              parent="menu_bb_project_root"
              action="action_bb_project_dashboard"
              sequence="1"/>

    <!-- ── Projects ──────────────────────────────── -->

    <menuitem id="menu_bb_project_projects"
              name="Projects"
              parent="menu_bb_project_root"
              sequence="10"/>

    <menuitem id="menu_bb_project_all"
              name="All Projects"
              parent="menu_bb_project_projects"
              action="action_bb_project"
              sequence="10"/>

    <menuitem id="menu_bb_project_my"
              name="My Projects"
              parent="menu_bb_project_projects"
              action="action_bb_project_my"
              sequence="20"/>

    <!-- ── Customers ──────────────────────────────── -->
    <record id="action_bb_project_customer" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
        <!-- Filter to typical customers, context ensures they have customer intent -->
        <field name="context">{'res_partner_search_mode': 'customer', 'default_is_company': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new customer
            </p>
            <p>
                Track all your project clients and business partners here.
            </p>
        </field>
    </record>

    <menuitem id="menu_bb_project_customers"
              name="Customers"
              parent="menu_bb_project_root"
              action="action_bb_project_customer"
              sequence="15"/>

    <!-- ── Tasks ──────────────────────────────── -->
    <menuitem id="menu_bb_project_tasks"
              name="Tasks"
              parent="menu_bb_project_root"
              sequence="20"/>

    <menuitem id="menu_bb_project_task_all"
              name="All Tasks"
              parent="menu_bb_project_tasks"
              action="action_bb_project_task"
              sequence="10"/>

    <menuitem id="menu_bb_project_task_my"
              name="My Tasks"
              parent="menu_bb_project_tasks"
              action="action_bb_project_task_my"
              sequence="20"/>

    <!-- ── Work Logs / Backlogs ──────────────────── -->
    <menuitem id="menu_bb_project_backlogs"
              name="Work Logs"
              parent="menu_bb_project_root"
              sequence="30"/>

    <menuitem id="menu_bb_project_backlog_all"
              name="All Work Logs"
              parent="menu_bb_project_backlogs"
              action="action_bb_project_backlog"
              sequence="10"/>

    <menuitem id="menu_bb_project_backlog_pending"
              name="Pending Approval"
              parent="menu_bb_project_backlogs"
              action="action_bb_project_backlog_pending"
              sequence="20"
              groups="bb_project_management.group_bb_pm_admin,bb_project_management.group_bb_pm_manager"/>

    <!-- ── Configuration ─────────────────────────── -->
    <menuitem id="menu_bb_project_config"
              name="Configuration"
              parent="menu_bb_project_root"
              sequence="99"
              groups="bb_project_management.group_bb_pm_admin,bb_project_management.group_bb_pm_manager"/>

    <menuitem id="menu_bb_project_tag_config"
              name="Tags"
              parent="menu_bb_project_config"
              action="action_bb_project_tag"
              sequence="10"
              groups="bb_project_management.group_bb_pm_admin,bb_project_management.group_bb_pm_manager"/>

</odoo>
